{
  "name": "us---a-shared-memory-journal",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config apps/web/vite.config.ts",
    "build": "vite build --config apps/web/vite.config.ts",
    "preview": "vite preview --config apps/web/vite.config.ts",
    "tauri": "tauri",
    "tauri:dev": "cross-env PATH=\"%USERPROFILE%\\.cargo\\bin;$PATH\" tauri dev --config apps/desktop/src-tauri/tauri.conf.json",
    "tauri:build": "cross-env PATH=\"%USERPROFILE%\\.cargo\\bin;$PATH\" tauri build --config apps/desktop/src-tauri/tauri.conf.json",
    "tauri:icon": "tauri icon \"apps/desktop/app-icon.png\" -o apps/desktop/src-tauri/icons"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/cli": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@supabase/supabase-js": "2.39.7",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-global-shortcut": "^2.3.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@types/matter-js": "^0.20.2",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.556.0",
    "matter-js": "^0.20.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.0",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.22",
    "cross-env": "^10.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.2.0"
  }
}
